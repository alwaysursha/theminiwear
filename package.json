{
  "name": "theminiwear",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:next": "WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --webpack",
    "dev:clean": "bash scripts/dev-clean.sh",
    "dev:db": "prisma dev start theminiwear -d",
    "dev:setup": "prisma dev start theminiwear -d && prisma db push && node --import tsx prisma/seed.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "build:cloudflare": "opennextjs-cloudflare build && bash scripts/prune-open-next-bundle.sh",
    "deploy": "pnpm build:cloudflare && opennextjs-cloudflare deploy",
    "deploy:cf": "pnpm build:cloudflare && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && bash scripts/prune-open-next-bundle.sh && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "stripe": "^22.2.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@ast-grep/napi-linux-x64-gnu": "0.40.5",
    "@cloudflare/workerd-linux-64": "1.20260623.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-pg": "^7.8.0",
    "date-fns": "^4.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.104.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "workerd",
      "@ast-grep/napi",
      "sharp"
    ]
  }
}
